# 🔹 Step 1: Import Libraries
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# 🔹 Step 2: Load Dataset
df = pd.read_csv('titanic.csv')   # make sure file is in same folder

# 🔹 Step 3: Basic Info
print("First 5 Rows:")
print(df.head())

print("\nDataset Info:")
print(df.info())

print("\nStatistical Summary:")
print(df.describe())

print("\nMissing Values:")
print(df.isnull().sum())

# 🔹 Step 4: Value Counts
print("\nSurvival Count:")
print(df['Survived'].value_counts())

print("\nGender Count:")
print(df['Sex'].value_counts())

# 🔹 Step 5: Data Cleaning
# Fill missing Age with mean
df['Age'].fillna(df['Age'].mean(), inplace=True)

# Drop Cabin column (too many missing values)
df.drop('Cabin', axis=1, inplace=True)

# Drop rows where Embarked is missing
df.dropna(subset=['Embarked'], inplace=True)

# 🔹 Step 6: Visualizations

# 1. Survival Count Plot
sns.countplot(x='Survived', data=df)
plt.title("Survival Count")
plt.show()

# 2. Gender vs Survival
sns.countplot(x='Sex', hue='Survived', data=df)
plt.title("Gender vs Survival")
plt.show()

# 3. Age Distribution
df['Age'].hist(bins=30)
plt.title("Age Distribution")
plt.show()

# 4. Fare vs Class
sns.boxplot(x='Pclass', y='Fare', data=df)
plt.title("Fare by Passenger Class")
plt.show()

# 5. Correlation Heatmap
sns.heatmap(df.corr(numeric_only=True), annot=True)
plt.title("Correlation Heatmap")
plt.show()

# 6. Pairplot
sns.pairplot(df)
plt.show()

# 🔹 Step 7: Observations (Print)
print("\n--- Observations ---")
print("1. Females have higher survival rate than males")
print("2. First class passengers survived more")
print("3. Higher fare passengers have better survival chances")
print("4. Age has moderate impact on survival")

# 🔹 Step 8: Conclusion
print("\n--- Conclusion ---")
print("Survival depends on gender, class, and fare. Wealthier and female passengers had higher survival chances.")
